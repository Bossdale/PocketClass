+/**
+ * templates/promptTemplates.ts
+ *
+ * Central registry of ALL LangChain PromptTemplates used across every AI service.
+ *
+ * ── SERVICE → PROMPT MAP ─────────────────────────────────────────────────────
+ *
+ *   SERVICE                   PROMPT(S) USED
+ *   ─────────────────────     ────────────────────────────────────────────────
+ *   DiagnosticQuizService   → diagnosticQuizPrompt
+ *   StudyPlanService        → diagnosticStudyPlanPrompt
+ *   LessonMaterialService   → lessonMaterialPrompt
+ *   LessonQuizService       → lessonQuizMCQPrompt
+ *                             lessonQuizTFPrompt
+ *                             lessonQuizFBPrompt
+ *   QuarterlyExamService    → quarterlyExamMCQPrompt
+ *                             quarterlyExamTFPrompt
+ *                             quarterlyExamFBPrompt
+ *   AITutorService          → aiTutorChatPrompt
+ *   AIExplanationService    → aiExplanationPrompt
+ *   FocusAreaService        → focusAreaPrompt
+ *
+ * ── OUTPUT TYPE MAP ──────────────────────────────────────────────────────────
+ *
+ *   PROMPT                       OUTPUT TYPE
+ *   ─────────────────────────    ───────────────────────────────────────────
+ *   diagnosticQuizPrompt       → MultipleChoiceQuestion[]     (5 items, easy)
+ *   diagnosticStudyPlanPrompt  → StudyPlan                    (4 quarters)
+ *   lessonMaterialPrompt       → LessonMaterial               (page1/2/3)
+ *   lessonQuizMCQPrompt        → MultipleChoiceQuestion[]     (1 item)
+ *   lessonQuizTFPrompt         → TrueFalseQuestion[]          (1 item)
+ *   lessonQuizFBPrompt         → FillBlankQuestion[]          (1 item)
+ *   quarterlyExamMCQPrompt     → QEMultipleChoiceQuestion[]   (n items)
+ *   quarterlyExamTFPrompt      → QETrueFalseQuestion[]        (n items)
+ *   quarterlyExamFBPrompt      → QEFillBlankQuestion[]        (n items)
+ *   aiTutorChatPrompt          → string                       (plain text)
+ *   aiExplanationPrompt        → string                       (plain text, TTS-safe)
+ *   focusAreaPrompt            → FocusAreaResponse            (JSON object)
+ *
+ * ── TEMPERATURE DEFAULTS ─────────────────────────────────────────────────────
+ *
+ *   0.1  quarterlyExamService     (highest determinism — seed rewriting)
+ *   0.3  diagnosticQuizPrompt     (baseline assessment — consistent)
+ *   0.3  lessonQuizPrompts        (quiz answers must not drift)
+ *   0.3  focusAreaPrompt          (dashboard widget — consistent output)
+ *   0.5  aiTutorChatPrompt        (balanced — personal but accurate)
+ *   0.5  aiExplanationPrompt      (natural spoken language)
+ *   0.6  lessonMaterialPrompt     (richer, more engaging lesson prose)
+ *
+ * ── KEY NOTES ────────────────────────────────────────────────────────────────
+ *   • All quiz prompts return JSON arrays with exactly 1 item (except
+ *     diagnosticQuizPrompt which returns 5, and quarterly exam prompts which
+ *     return {questionCount} items). Always unwrap [0] for single-question calls.
+ *   • how_to_get_high_scores is returned as string[] from the prompt — ensure
+ *     StudyPlan interface declares it as string[] (not string).
+ *   • MCQ correctOption (0-based index) is used in lesson quiz prompts.
+ *     MCQ correctAnswer (option text string) is used in quarterly exam prompts.
+ *     Never mix these up in result-saving or QuizRenderer logic.
+ */
